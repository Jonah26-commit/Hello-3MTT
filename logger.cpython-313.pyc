"""Terminal color codes — cross-platform."""
import platform

# Disable colors on Windows if not supported
_WIN = platform.system() == "Windows"

try:
    if _WIN:
        import ctypes
        kernel32 = ctypes.windll.kernel32
        kernel32.SetConsoleMode(kernel32.GetStdHandle(-11), 7)
    _COLORS = True
except Exception:
    _COLORS = False


class Colors:
    if _COLORS:
        RED     = "\033[91m"
        GREEN   = "\033[92m"
        YELLOW  = "\033[93m"
        CYAN    = "\033[96m"
        BOLD    = "\033[1m"
        DIM     = "\033[2m"
        RESET   = "\033[0m"
    else:
        RED = GREEN = YELLOW = CYAN = BOLD = DIM = RESET = ""
